# Database
POSTGRES_PASSWORD=your_strong_password
DATABASE_URL=postgresql://fpvuser:your_strong_password@localhost:5432/fpvshop

# Redis
REDIS_PASSWORD=your_redis_password
REDIS_URL=redis://:your_redis_password@localhost:6379

# JWT (min 32 chars)
JWT_SECRET=your_jwt_secret_min_32_characters_long
JWT_REFRESH_SECRET=your_refresh_secret_min_32_characters_long

# WayForPay
WAYFORPAY_MERCHANT_ACCOUNT=your_merchant_account
WAYFORPAY_MERCHANT_KEY=your_merchant_key
WAYFORPAY_DOMAIN=fpvshop.ua

# Nova Poshta
NOVA_POSHTA_API_KEY=your_np_api_key
NOVA_POSHTA_SENDER_REF=your_sender_warehouse_ref

# Email (SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your@gmail.com
SMTP_PASS=your_app_password
EMAIL_FROM=FPV Shop <noreply@fpvshop.ua>

# Algolia Search
ALGOLIA_APP_ID=your_app_id
ALGOLIA_API_KEY=your_admin_api_key
ALGOLIA_INDEX=fpv_products

# Storage (Supabase / Cloudflare R2)
STORAGE_URL=https://your-project.supabase.co/storage/v1
STORAGE_BUCKET=fpv-shop
STORAGE_KEY=your_storage_key
STORAGE_SECRET=your_storage_secret

# URLs
FRONTEND_URL=https://fpvshop.ua
ADMIN_URL=https://admin.fpvshop.ua
NEXT_PUBLIC_API_URL=https://api.fpvshop.ua/api/v1
NEXT_PUBLIC_SITE_URL=https://fpvshop.ua

# Checkbox (ПРРО) - optional
CHECKBOX_API_KEY=
CHECKBOX_CASHIER_PIN=

# Supabase (if using alt stack)
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your_anon_key
SUPABASE_SERVICE_KEY=your_service_role_key
